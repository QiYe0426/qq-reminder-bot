HOST=127.0.0.1
PORT=8080
LOG_LEVEL=INFO
COMMAND_START=["/"]

# QQ user IDs allowed to run admin-only commands, separated by commas.
# Admin-only commands: 启用/开启🎒常数报时, 关闭🎒常数报时.
BOT_ADMIN_USER_IDS=

# Server-only AI settings. Copy these lines to .env.local and fill in the real key.
# Do not commit .env.local to GitHub.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_SECONDS=30
AI_MAX_QUESTION_LENGTH=800
AI_MAX_REPLY_LENGTH=1200

# Experimental media insight pipeline. Keep disabled unless testing.
MEDIA_INSIGHTS_ENABLED=0
MEDIA_INSIGHTS_AUTO_ENABLED=1
MEDIA_INSIGHTS_BATCH_SIZE=30
IMAGE_VISION_ENABLED=0
IMAGE_VISION_MODEL=qwen-vl-plus
IMAGE_VISION_API_KEY=
IMAGE_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGE_VISION_TIMEOUT_SECONDS=45
SUMMARY_MODEL=deepseek-v4-pro
